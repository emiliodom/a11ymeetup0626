{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,

  "name": "create-block/my-notice-block",
  "version": "1.0.0",

  "title": "My Notice Block",
  "category": "common",
  "icon": "info",
  "description": "An accessible notice / call-to-action block. Built at the WordPress Accessibility Meetup — June 2026.",
  "keywords": ["notice", "alert", "cta", "accessibility"],

  "textdomain": "my-notice-block",

  "editorScript": "file:./index.js",
  "editorStyle":  "file:./index.css",
  "style":        "file:./style-index.css",

  "attributes": {
    "noticeText": {
      "type": "string",
      "default": "Write your notice here..."
    },
    "noticeType": {
      "type": "string",
      "default": "info"
    }
  },

  "supports": {
    "html":    false,
    "align":   ["wide", "full"],
    "anchor":  true,
    "color": {
      "background": true,
      "text":       true
    },
    "spacing": {
      "padding": true,
      "margin":  true
    },
    "typography": {
      "fontSize": true
    }
  },

  "example": {
    "attributes": {
      "noticeText": "This is an example notice block.",
      "noticeType": "info"
    }
  }
}
